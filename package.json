{
   "name": "electrobun-react-tailwind-vite",
   "version": "1.0.0",
   "description": "Electrobun app with React, Tailwind CSS, and Vite HMR",
   "scripts": {
      "start": "vite build && electrobun dev",
      "dev": "electrobun dev --watch",
      "dev:hmr": "bun run --parallel hmr dev",
      "hmr": "vite --port 5173",
      "build": "vite build && electrobun build --env=stable"
   },
   "dependencies": {
      "@tailwindcss/vite": "^4.2.1",
      "clsx": "^2.1.1",
      "electrobun": "1.15.1",
      "oxfmt": "^0.40.0",
      "react": "^19.2.4",
      "react-dom": "^19.2.4",
      "vdf-parser": "^1.2.1"
   },
   "devDependencies": {
      "@types/bun": "latest",
      "@types/react": "^19.2.14",
      "@types/react-dom": "^19.2.3",
      "@vitejs/plugin-react": "^6.0.1",
      "concurrently": "^9.2.1",
      "postcss": "^8.5.8",
      "tailwindcss": "^4.2.1",
      "typescript": "^5.9.3",
      "vite": "^8.0.0"
   }
}
